# ============================================================
# CleanDesktop Configuration
# Copy this file to .env and edit as needed
# ============================================================

# Source directory to clean (default: ~/Desktop)
CLEANDESKTOP_SOURCE=~/Desktop

# Archive root directory (default: ~/Desktop/archive)
CLEANDESKTOP_ARCHIVE=~/Desktop/archive

# CSV log file path (default: <archive>/archive_log.csv)
CLEANDESKTOP_LOG=

# Default category tag when not specified
# Options: work, personal, project, notes, other
CLEANDESKTOP_CATEGORY=other
